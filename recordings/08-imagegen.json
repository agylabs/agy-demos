{
  "settings": {
    "width": 1280, "height": 720, "fps": 30, "font_size": 14,
    "theme": "dracula", "output": "videos/08-imagegen.mp4",
    "shell_command": "DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus agy --dangerously-skip-permissions",
    "startup_delay": 8,
    "subtitle_style": "FontName=Sans,FontSize=16,PrimaryColour=&H00FFFFFF,OutlineColour=&H40000000,BackColour=&H40000000,Outline=1,Shadow=1,BorderStyle=4,MarginV=20,MarginL=40,MarginR=40"
  },
  "actions": [
    {"at": 0.0,  "type": "subtitle", "text": "AGY CLI  ·  Demo 8: Image Generation"},
    {"at": 3.0,  "type": "subtitle", "text": "Generate images on-the-fly — no external tools needed"},
    {"at": 4.0,  "type": "type", "text": "Generate an image of a majestic lion in outer space surrounded by colorful nebulas. Save it as lion.png", "speed": 20},
    {"at": 9.0,  "type": "key", "key": "Enter"},
    {"at": 11.0, "type": "subtitle", "text": "agy calls GenerateImage() — creating the image inline"},
    {"at": 11.1, "type": "wait_until_idle", "pattern": "? for shortcuts", "timeout": 120, "poll": 2, "buffer": 2},

    {"at": 12.0, "type": "subtitle", "text": "Image generated — let's view it in the browser"},
    {"at": 14.0, "type": "show_browser", "url": "./lion.png", "duration": 6.0, "subtitle": "The generated lion in outer space"},
