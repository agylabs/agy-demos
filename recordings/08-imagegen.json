    {"at": 23.0, "type": "subtitle", "text": "Now let's modify the image with another prompt"},
    {"at": 24.0, "type": "type", "text": "Edit the lion image to add a glowing golden crown on its head and make the nebula colors more vibrant. Save as lion-crowned.png", "speed": 18},
    {"at": 31.0, "type": "key", "key": "Enter"},
    {"at": 33.0, "type": "subtitle", "text": "Iterative workflow — generate, view, refine"},
    {"at": 33.1, "type": "wait_until_idle", "pattern": "? for shortcuts", "timeout": 120, "poll": 2, "buffer": 2},

    {"at": 34.0, "type": "subtitle", "text": "Modified image ready — viewing the updated version"},
    {"at": 36.0, "type": "show_browser", "url": "./lion-crowned.png", "duration": 6.0, "subtitle": "The lion now has a glowing crown"},
    {"at": 43.0, "type": "close_browser"},

    {"at": 45.0, "type": "subtitle", "text": "Image Gen: create, iterate, and refine — all inside agy CLI"},
    {"at": 49.0, "type": "wait", "duration": 1.0}
  ]
